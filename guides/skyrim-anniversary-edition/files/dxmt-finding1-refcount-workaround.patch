 extern "C" void __cxa_pure_virtual() {
-  dxmt::Logger::err(dxmt::str::format("Pure virtual function called"));
+  // DXMT-POC instrumentation: capture `this` (Win64 ABI -> rcx) and read the
+  // Itanium RTTI (vtable[-1] -> type_info) to name the object whose interface
+  // method is unimplemented, before trapping.
+  void *self;
+  __asm__ volatile("movq %%rcx, %0" : "=r"(self));
+  void *caller = __builtin_return_address(0);
+  const char *tname = "<unknown>";
+  if (self) {
+    void **vt = *reinterpret_cast<void ***>(self);
+    if (vt) {
+      const std::type_info *ti =
+          *(reinterpret_cast<const std::type_info *const *>(vt) - 1);
+      if (ti && ti->name())
+        tname = ti->name();
+    }
+  }
+  dxmt::Logger::err(dxmt::str::format(
+      "Pure virtual function called: type=", tname, " this=", self,
+      " caller=", caller));
   __builtin_trap();
 }
