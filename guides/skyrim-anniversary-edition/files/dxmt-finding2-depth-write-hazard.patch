             depth.load_action = WMTLoadActionLoad;
             depth.store_action = WMTStoreActionStore;
@@ -4513,6 +4519,8 @@ public:
 
           if (dsv_planar_flags & 2) {
             auto &stencil = info.stencil;
+            auto access_flag = (dsv.ReadOnlyFlags & 0x2) ? ResourceAccess::Read
